model User {
  id         String   @id
  sl         Int      @unique @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  //! auth
  role           EUserRole @default(USER)
  email          String    @unique
  password       String
  is_verified    Boolean   @default(false)
  is_active      Boolean   @default(false)
  is_admin       Boolean   @default(false)
  is_super_admin Boolean   @default(false)
  otp_id         Int       @default(0)
  //! end

  //! profile
  avatar   String? @default("/images/placeholder.png")
  name     String  @default("Getavails User")
  gender   EGender @default(OTHER)
  location String?
  //! end

  //! payment
  balance                 Float     @default(0)
  stripe_customer_id      String?
  stripe_account_id       String?
  is_stripe_connected     Boolean   @default(false)
  subscription_name       String?
  subscription_expires_at DateTime?
  //! end

  experience               String?
  genre                    String?
  availability             DateTime[]   @default([]) // Todo: so reference not embedded
  price                    String?
  venue_type               String?
  capacity                 Int?
  agent_artists            String[]     @default([])
  agent_pending_artists    String[]     @default([])
  artist_agents            String[]     @default([])
  artist_pending_agents    String[]     @default([])
  organizer_active_artists AgentOffer[] @relation("ActiveAgentOffers")
  organizer_active_venues  VenueOffer[] @relation("ActiveVenueOffers")

  seen_messages           Message[]     @relation("SeenMessages")
  messages                Message[]
  chats                   Chat[]        @relation("UserChats")
  agent_offers_agents     AgentOffer[]  @relation("AgentOffersAgent")
  agent_offers_artists    AgentOffer[]  @relation("AgentOffersArtist")
  agent_offers_organizers AgentOffer[]  @relation("AgentOffersOrganizer")
  venue_offers_organizers VenueOffer[]  @relation("VenueOffersOrganizer")
  venue_offers_venues     VenueOffer[]  @relation("VenueOffersVenue")
  organizer_events        Event[]
  tickets                 Ticket[]
  blogs                   Blog[]
  transactions            Transaction[]
  offers_as_venue         Offer[]       @relation("OfferVenue")
  offers_as_agent         Offer[]       @relation("OfferAgent")
  offers_as_artist        Offer[]       @relation("OfferArtist")
  offers_as_organizer     Offer[]       @relation("OfferOrganizer")
  offers_as_tour_manager  Offer[]       @relation("OfferTourManager")
  calendar                Calendar?

  @@map("users")
}

enum EUserRole {
  USER
  ORGANIZER
  VENUE
  ARTIST
  AGENT
  TOUR_MANAGER
}

enum EGender {
  MALE
  FEMALE
  OTHER
}
