model SystemEventPerformer {
  event_id     String
  performer_id String

  event     SystemEvent     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  performer SystemPerformer @relation(fields: [performer_id], references: [id], onDelete: Cascade)

  @@id([event_id, performer_id])
  @@map("systemEventPerformers")
}
