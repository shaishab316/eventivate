model SystemVenue {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name String

  //? location details
  address   String
  city      String
  state     String
  zip       String @map("postal_code")
  country   String
  latitude  Float  @map("lat")
  longitude Float  @map("lng")

  capacity Int
  score    Float?

  source      SystemSource
  source_id   String
  source_slug String
  source_url  String

  events SystemEvent[]

  @@unique([source, source_id])
  @@index([latitude, longitude])
  @@map("system_venues")
}

enum SystemSource {
  SEATGEEK @map("seatgeek")
}
